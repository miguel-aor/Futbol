# =========================================================
# Futbol - Prototipo interno de analisis del Mundial 2026
# =========================================================
# La app FUNCIONA SIN NINGUNA de estas variables (usa mock data).
# Copia este archivo a `.env.local` solo si quieres cambiar defaults.
# NUNCA subas secretos reales al repositorio.

# Proveedor de datos activo: mock | manual | 365scores
DATA_PROVIDER=mock

# Habilita la lectura de snapshots experimentales de 365Scores.
# El scraping NUNCA corre en build ni en cada request: solo via `npm run ingest:365`.
ENABLE_365_EXPERIMENTAL=false

# Reservado para una futura integracion con una API deportiva oficial.
# Dejar vacio no rompe la app.
SPORTS_API_KEY=
SPORTS_API_BASE_URL=

# Reservado para una futura persistencia. Dejar vacio no rompe la app.
DATABASE_URL=
