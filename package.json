    "wc:elo": "tsx scripts/build-team-elo-history.ts",
    "wc:form": "tsx scripts/build-current-worldcup-form.ts",
    "wc:features": "tsx scripts/build-prediction-features.ts",
    "wc:props": "tsx scripts/build-player-prop-features.ts",
    "wc:events": "tsx scripts/build-match-events.ts",
