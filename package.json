    "wc:build": "npm run wc:sync && npm run wc:playerstats && npm run wc:365 && npm run wc:elo && npm run wc:form && npm run wc:features && npm run wc:props && npm run wc:events && npm run wc:validate"
  },
  "dependencies": {
